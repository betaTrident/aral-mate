---
// src/pages/index.astro
import '@/index.css'
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AralMate - AI School Task Organizer for Busy Parents</title>
    <meta
      name="description"
      content="Turn chaotic Viber, Messenger, and WhatsApp school group chats into an organized dashboard of tasks, deadlines, and announcements using Gemini AI."
    />
    
    <!-- SEO Meta Tags -->
    <meta property="og:title" content="AralMate - AI School Task Organizer for Parents" />
    <meta property="og:description" content="Turn chaotic teacher announcements and group chats into a structured dashboard of homework, fees, and school events." />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Lucide Icons (Via ESM) -->
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <script is:inline>
      // Automatically run lucide icon replacement
      document.addEventListener('DOMContentLoaded', () => {
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }
      });
    </script>
  </head>
  <body class="bg-[#030712] text-slate-100 antialiased font-sans overflow-x-hidden">
    <a
      href="#main-content"
      class="fixed left-4 top-4 z-[100] -translate-y-24 rounded-lg bg-amber-400 px-4 py-2 font-semibold text-slate-950 shadow-xl transition-transform focus:translate-y-0"
    >Skip to main content</a>
    
    <!-- Ambient glowing backgrounds -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-indigo-600/15 rounded-full blur-[120px]"></div>
      <div class="absolute top-[40%] -left-60 w-[500px] h-[500px] bg-amber-500/10 rounded-full blur-[100px]"></div>
      <div class="absolute bottom-10 right-10 w-[500px] h-[500px] bg-purple-600/10 rounded-full blur-[100px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#1f29370a_1px,transparent_1px),linear-gradient(to_bottom,#1f29370a_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    </div>

    <!-- Header Navigation -->
    <header class="relative z-50 border-b border-white/5 bg-slate-950/40 backdrop-blur-md sticky top-0">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        
        <!-- Logo -->
        <a href="/" aria-label="AralMate home" class="flex items-center gap-3 group">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 via-purple-500 to-amber-500 p-[1px] shadow-lg shadow-indigo-500/20 group-hover:scale-105 transition-all duration-300">
            <div class="w-full h-full rounded-[11px] bg-slate-950 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-400 group-hover:text-indigo-300 transition-colors"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/><path d="M21.5 12v6"/></svg>
            </div>
          </div>
          <div>
            <span class="font-display font-extrabold text-xl bg-clip-text text-transparent bg-gradient-to-r from-white via-slate-100 to-indigo-200">AralMate</span>
            <span class="block text-[10px] text-indigo-400 font-semibold tracking-wider uppercase leading-none">AI School Companion</span>
          </div>
        </a>

        <!-- Desktop Nav Links -->
        <nav class="hidden md:flex items-center gap-8">
          <a href="#features" class="text-sm text-slate-400 hover:text-white transition-colors">Features</a>
          <a href="#how-it-works" class="text-sm text-slate-400 hover:text-white transition-colors">How It Works</a>
          <a href="#playground" class="text-sm text-slate-400 hover:text-white transition-colors">Interactive Demo</a>
          <a href="#faq" class="text-sm text-slate-400 hover:text-white transition-colors">FAQ</a>
        </nav>

        <!-- CTA Action -->
        <div class="flex items-center gap-4">
          <details class="relative md:hidden">
            <summary class="cursor-pointer list-none rounded-lg border border-white/10 px-3 py-2 text-sm font-semibold text-slate-200">Navigate</summary>
            <nav
              aria-label="Mobile section navigation"
              class="absolute right-0 top-12 z-50 w-52 rounded-xl border border-white/10 bg-slate-950 p-2 shadow-2xl"
            >
              <a href="#features" class="block rounded-lg px-3 py-2 text-sm text-slate-300 hover:bg-white/10">Features</a>
              <a href="#how-it-works" class="block rounded-lg px-3 py-2 text-sm text-slate-300 hover:bg-white/10">How It Works</a>
              <a href="#playground" class="block rounded-lg px-3 py-2 text-sm text-slate-300 hover:bg-white/10">Interactive Demo</a>
              <a href="#faq" class="block rounded-lg px-3 py-2 text-sm text-slate-300 hover:bg-white/10">FAQ</a>
            </nav>
          </details>
          <a
            id="nav-launch-app"
            href="/app"
            class="relative inline-flex items-center justify-center p-0.5 mb-2 mr-2 overflow-hidden text-sm font-semibold rounded-xl group bg-gradient-to-br from-indigo-500 via-purple-600 to-amber-500 group-hover:from-indigo-500 group-hover:to-amber-500 text-white focus:ring-4 focus:outline-none focus:ring-indigo-800 transition-all duration-300 mt-2"
          >
            <span class="relative px-5 py-2 transition-all ease-in duration-75 bg-slate-950 rounded-[10px] group-hover:bg-opacity-0">
              Launch App
            </span>
          </a>
        </div>
      </div>
    </header>

    <main id="main-content" class="relative z-10">

      <!-- Hero Section -->
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-20 md:pt-20 md:pb-28">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          
          <!-- Left Column (Content) -->
          <div class="lg:col-span-7 text-center lg:text-left space-y-6">
            
            <!-- Gemini Tag -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/30 text-indigo-300 text-xs font-semibold tracking-wide uppercase mx-auto lg:mx-0 animate-fade-in shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-400 animate-pulse"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              Powered by Gemini AI
            </div>

            <!-- Headline -->
            <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.1] sm:leading-none">
              Turn Chaotic <span class="bg-clip-text text-transparent bg-gradient-to-r from-amber-400 via-orange-400 to-pink-500">School Group Chats</span> Into An Organized Dashboard
            </h1>

            <!-- Subtitle -->
            <p class="text-lg text-slate-300 max-w-xl mx-auto lg:mx-0 font-normal leading-relaxed">
              AralMate instantly extracts homework, due dates, project fees, and announcements from Viber, WhatsApp, and email messages. No manual sorting, no forgotten deadlines.
            </p>

            <!-- Hero CTAs -->
            <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-4">
              <a
                id="hero-cta-launch"
                href="/app"
                class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-indigo-500 via-purple-600 to-pink-600 hover:from-indigo-600 hover:via-purple-700 hover:to-pink-700 text-white font-semibold rounded-xl text-center shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 hover:-translate-y-0.5 transition-all duration-200"
              >
                Get Started Free
              </a>
              <a
                href="#playground"
                class="w-full sm:w-auto px-8 py-4 bg-slate-900/60 hover:bg-slate-800/80 border border-white/10 hover:border-white/20 text-slate-200 font-semibold rounded-xl text-center backdrop-blur-sm transition-all duration-200"
              >
                Try Live Playground
              </a>
            </div>

            <!-- Social Proof / Stats -->
            <div class="pt-8 border-t border-white/5 flex flex-wrap justify-center lg:justify-start gap-8 text-slate-400 text-sm">
              <div class="flex items-center gap-2">
                <i data-lucide="check-circle" class="w-4 h-4 text-emerald-400"></i>
                <span>No account required</span>
              </div>
              <div class="flex items-center gap-2">
                <i data-lucide="shield-check" class="w-4 h-4 text-emerald-400"></i>
                <span>Privacy First (Local storage)</span>
              </div>
              <div class="flex items-center gap-2">
                <i data-lucide="globe" class="w-4 h-4 text-emerald-400"></i>
                <span>Supports Tagalog/Filipino messages</span>
              </div>
            </div>

          </div>

          <!-- Right Column (Interactive Showcase Graphic) -->
          <div class="lg:col-span-5 relative mt-6 lg:mt-0">
            <div class="absolute -inset-1 rounded-2xl bg-gradient-to-tr from-indigo-500 via-purple-600 to-amber-500 opacity-30 blur-lg"></div>
            
            <div class="relative bg-slate-950/80 border border-white/10 rounded-2xl p-4 sm:p-6 backdrop-blur-xl shadow-2xl space-y-6">
              
              <!-- Tab toggler for Showcase -->
              <div class="flex items-center justify-between border-b border-white/5 pb-4">
                <div class="flex gap-2">
                  <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
                  <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
                </div>
                
                <div class="bg-slate-900/90 rounded-lg p-0.5 flex border border-white/5" role="tablist" aria-label="Before and after comparison">
                  <button id="btn-show-chaos" role="tab" aria-selected="true" aria-controls="showcase-chaos" class="px-3 py-1.5 text-xs font-semibold rounded-md transition-all duration-200 bg-indigo-500/20 text-indigo-200">
                    Parent Group Chat
                  </button>
                  <button id="btn-show-clarity" role="tab" aria-selected="false" aria-controls="showcase-clarity" tabindex="-1" class="px-3 py-1.5 text-xs font-semibold rounded-md transition-all duration-200 text-slate-400 hover:text-slate-200">
                    AralMate Dashboard
                  </button>
                </div>
              </div>

              <!-- Content Cards Wrapper -->
              <div class="min-h-[290px] relative overflow-hidden flex items-center justify-center">
                
                <!-- Card A: Chaos (Group Chat Bubble Screen) -->
                <div id="showcase-chaos" role="tabpanel" aria-labelledby="btn-show-chaos" class="w-full space-y-4 transition-all duration-300 transform scale-100 opacity-100">
                  <div class="flex gap-3 items-end">
                    <div class="w-7 h-7 rounded-full bg-rose-600 flex items-center justify-center font-display font-bold text-xs text-white">TS</div>
                    <div class="bg-slate-900 border border-slate-800 rounded-2xl rounded-bl-none p-3 max-w-[85%] text-xs text-slate-300">
                      <p class="font-bold text-rose-400 mb-1">Teacher Santos (Grade 3)</p>
                      Good morning parents! Please be reminded: Math worksheet on fractions due June 12, book rental fee of P150 due June 15 to the treasurer, and science project draw parts of a plant due Friday June 14. Thank you!
                    </div>
                  </div>

                  <div class="flex gap-3 items-end justify-end">
                    <div class="bg-indigo-950 border border-indigo-900 rounded-2xl rounded-br-none p-3 max-w-[80%] text-xs text-slate-300">
                      <p class="font-bold text-indigo-400 mb-1">Mom of Lucas (You)</p>
                      Hala! Homework pages 45-47 po ba yung sa fractions? Saka saan po magbabayad ng fee?
                    </div>
                    <div class="w-7 h-7 rounded-full bg-indigo-600 flex items-center justify-center font-display font-bold text-xs text-white">ME</div>
                  </div>

                  <div class="flex gap-3 items-end">
                    <div class="w-7 h-7 rounded-full bg-rose-600 flex items-center justify-center font-display font-bold text-xs text-white">TS</div>
                    <div class="bg-slate-900 border border-slate-800 rounded-2xl rounded-bl-none p-3 max-w-[85%] text-xs text-slate-300">
                      <p class="font-bold text-rose-400 mb-1">Teacher Santos (Grade 3)</p>
                      Yes, fractions page 45-47 correct. Book fee pay to Class Treasurer Mommy Reyes. Pls bring white shoes on Monday flag ceremony.
                    </div>
                  </div>
                </div>

                <!-- Card B: Clarity (AralMate organized tasks) -->
                <div id="showcase-clarity" role="tabpanel" aria-labelledby="btn-show-clarity" class="w-full space-y-3 transition-all duration-300 transform translate-x-12 opacity-0 hidden">
                  
                  <div class="bg-slate-900/60 border border-white/5 rounded-xl p-3 flex items-center justify-between hover:bg-slate-900 transition-colors">
                    <div class="flex items-center gap-3">
                      <div class="w-2.5 h-2.5 rounded-full bg-rose-500 animate-pulse"></div>
                      <div>
                        <p class="text-xs font-semibold text-white">Math Worksheet — Fractions (pp. 45-47)</p>
                        <p class="text-[10px] text-slate-400">Mathematics • Due Tomorrow</p>
                      </div>
                    </div>
                    <span class="px-2 py-0.5 rounded-md bg-rose-500/10 text-rose-400 text-[10px] font-bold border border-rose-500/20">High Priority</span>
                  </div>

                  <div class="bg-slate-900/60 border border-white/5 rounded-xl p-3 flex items-center justify-between hover:bg-slate-900 transition-colors">
                    <div class="flex items-center gap-3">
                      <div class="w-2.5 h-2.5 rounded-full bg-rose-500"></div>
                      <div>
                        <p class="text-xs font-semibold text-white">Science Project — Parts of a Plant</p>
                        <p class="text-[10px] text-slate-400">Science • Due Friday</p>
                      </div>
                    </div>
                    <span class="px-2 py-0.5 rounded-md bg-rose-500/10 text-rose-400 text-[10px] font-bold border border-rose-500/20">High Priority</span>
                  </div>

                  <div class="bg-slate-900/60 border border-white/5 rounded-xl p-3 flex items-center justify-between hover:bg-slate-900 transition-colors">
                    <div class="flex items-center gap-3">
                      <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
                      <div>
                        <p class="text-xs font-semibold text-white">Pay Book Rental Fee ₱150</p>
                        <p class="text-[10px] text-slate-400">Administrative • Due June 15</p>
                      </div>
                    </div>
                    <span class="px-2 py-0.5 rounded-md bg-amber-500/10 text-amber-400 text-[10px] font-bold border border-amber-500/20">Medium Priority</span>
                  </div>

                  <!-- Mini Banner -->
                  <div class="bg-emerald-950/20 border border-emerald-500/10 rounded-lg p-2.5 text-center">
                    <p class="text-[11px] text-emerald-400 font-semibold flex items-center justify-center gap-1.5">
                      <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
                      Viber chat parsed into 3 tasks and 1 event timeline!
                    </p>
                  </div>

                </div>

              </div>
              
              <!-- Subtle instruction indicator -->
              <p class="text-[11px] text-center text-slate-500 italic">
                AralMate separates clean action-items from chatter. Click options above to compare.
              </p>

            </div>
          </div>

        </div>
      </section>

      <!-- Before/After Tab Logic Script -->
      <script is:inline>
        const btnChaos = document.getElementById('btn-show-chaos');
        const btnClarity = document.getElementById('btn-show-clarity');
        const cardChaos = document.getElementById('showcase-chaos');
        const cardClarity = document.getElementById('showcase-clarity');

        if (btnChaos && btnClarity && cardChaos && cardClarity) {
          btnChaos.addEventListener('click', () => {
            btnChaos.setAttribute('aria-selected', 'true');
            btnChaos.tabIndex = 0;
            btnClarity.setAttribute('aria-selected', 'false');
            btnClarity.tabIndex = -1;
            btnChaos.classList.add('bg-indigo-500/20', 'text-indigo-200');
            btnChaos.classList.remove('text-slate-400');
            btnClarity.classList.remove('bg-indigo-500/20', 'text-indigo-200');
            btnClarity.classList.add('text-slate-400');

            cardChaos.classList.remove('hidden');
            setTimeout(() => {
              cardChaos.classList.add('scale-100', 'opacity-100');
              cardChaos.classList.remove('translate-x-12', 'opacity-0');
            }, 50);

            cardClarity.classList.add('hidden', 'translate-x-12', 'opacity-0');
            cardClarity.classList.remove('scale-100', 'opacity-100');
          });

          btnClarity.addEventListener('click', () => {
            btnClarity.setAttribute('aria-selected', 'true');
            btnClarity.tabIndex = 0;
            btnChaos.setAttribute('aria-selected', 'false');
            btnChaos.tabIndex = -1;
            btnClarity.classList.add('bg-indigo-500/20', 'text-indigo-200');
            btnClarity.classList.remove('text-slate-400');
            btnChaos.classList.remove('bg-indigo-500/20', 'text-indigo-200');
            btnChaos.classList.add('text-slate-400');

            cardClarity.classList.remove('hidden');
            setTimeout(() => {
              cardClarity.classList.add('scale-100', 'opacity-100');
              cardClarity.classList.remove('translate-x-12', 'opacity-0');
            }, 50);

            cardChaos.classList.add('hidden', 'translate-x-12', 'opacity-0');
            cardChaos.classList.remove('scale-100', 'opacity-100');
          });

          [btnChaos, btnClarity].forEach((tab, index, tabs) => {
            tab.addEventListener('keydown', event => {
              if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
              event.preventDefault();
              const nextIndex = event.key === 'ArrowRight'
                ? (index + 1) % tabs.length
                : (index - 1 + tabs.length) % tabs.length;
              tabs[nextIndex].focus();
              tabs[nextIndex].click();
            });
          });
        }
      </script>


      <!-- Value Proposition / Product Highlights -->
      <section id="features" class="relative bg-slate-950/60 border-t border-b border-white/5 py-20 backdrop-blur-sm">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          
          <div class="text-center space-y-3 mb-16">
            <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-white">
              Designed For Busy Parents Who Need Clarity
            </h2>
            <p class="text-slate-400 max-w-xl mx-auto text-base">
              Say goodbye to endless message scrolling, missed announcements, and forgotten project materials.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <!-- Feature 1: AI Parse -->
            <div class="group bg-slate-900/40 hover:bg-slate-900 border border-white/5 hover:border-indigo-500/30 p-6 rounded-2xl transition-all duration-300 shadow-xl">
              <div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 border border-indigo-500/20">
                <i data-lucide="sparkles" class="w-6 h-6 text-indigo-400"></i>
              </div>
              <h3 class="font-display font-bold text-lg text-white mb-2">Gemini AI Parser</h3>
              <p class="text-sm text-slate-400 leading-relaxed">
                Pasted announcements are immediately decoded to find hidden action items. No matter how messy, Gemini pulls out exact titles, subjects, and instructions.
              </p>
            </div>

            <!-- Feature 2: Smart Due Dates -->
            <div class="group bg-slate-900/40 hover:bg-slate-900 border border-white/5 hover:border-purple-500/30 p-6 rounded-2xl transition-all duration-300 shadow-xl">
              <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 border border-purple-500/20">
                <i data-lucide="calendar" class="w-6 h-6 text-purple-400"></i>
              </div>
              <h3 class="font-display font-bold text-lg text-white mb-2">Timeline Chronology</h3>
              <p class="text-sm text-slate-400 leading-relaxed">
                Tasks are mapped to an intuitive timeline showing exactly what is due tomorrow, this Friday, or next week. Stay ahead of project submission cycles.
              </p>
            </div>

            <!-- Feature 3: Privacy First -->
            <div class="group bg-slate-900/40 hover:bg-slate-900 border border-white/5 hover:border-emerald-500/30 p-6 rounded-2xl transition-all duration-300 shadow-xl">
              <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 border border-emerald-500/20">
                <i data-lucide="lock" class="w-6 h-6 text-emerald-400"></i>
              </div>
              <h3 class="font-display font-bold text-lg text-white mb-2">Offline Privacy</h3>
              <p class="text-sm text-slate-400 leading-relaxed">
                No accounts, no email lists, and no data leaks. Your child's profiles and class tasks are saved locally on your browser's local storage.
              </p>
            </div>

            <!-- Feature 4: Filipino School Context -->
            <div class="group bg-slate-900/40 hover:bg-slate-900 border border-white/5 hover:border-amber-500/30 p-6 rounded-2xl transition-all duration-300 shadow-xl">
              <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 border border-amber-500/20">
                <i data-lucide="languages" class="w-6 h-6 text-amber-400"></i>
              </div>
              <h3 class="font-display font-bold text-lg text-white mb-2">Local Language Support</h3>
              <p class="text-sm text-slate-400 leading-relaxed">
                Trained to interpret Taglish, colloquial Filipino, and common local education terms (e.g. "baon", "recitation", "mga magulang", "class treasurer").
              </p>
            </div>

            <!-- Feature 5: Child Profile Settings -->
            <div class="group bg-slate-900/40 hover:bg-slate-900 border border-white/5 hover:border-pink-500/30 p-6 rounded-2xl transition-all duration-300 shadow-xl">
              <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 border border-pink-500/20">
                <i data-lucide="users" class="w-6 h-6 text-pink-400"></i>
              </div>
              <h3 class="font-display font-bold text-lg text-white mb-2">Focus Profiles</h3>
              <p class="text-sm text-slate-400 leading-relaxed">
                Keep tasks organized with child profiles. Know exactly which assignment belongs to which kid, keeping your focus crystal clear.
              </p>
            </div>

            <!-- Feature 6: Checkoff Success -->
            <div class="group bg-slate-900/40 hover:bg-slate-900 border border-white/5 hover:border-blue-500/30 p-6 rounded-2xl transition-all duration-300 shadow-xl">
              <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 border border-blue-500/20">
                <i data-lucide="clipboard-check" class="w-6 h-6 text-blue-400"></i>
              </div>
              <h3 class="font-display font-bold text-lg text-white mb-2">Completion Toggles</h3>
              <p class="text-sm text-slate-400 leading-relaxed">
                Check off items as you complete them. Get visual clarity of remaining items for the day and easily review finished tasks.
              </p>
            </div>

          </div>

