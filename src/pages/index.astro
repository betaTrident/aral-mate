      <!-- Interactive Playground Logic Script -->
      <script is:inline>
        const btnSimulate = document.getElementById('btn-simulate-parse');
        const btnReset = document.getElementById('btn-parse-another');
        const btnLoadDemo = document.getElementById('btn-load-demo');
        
        const simInputPanel = document.getElementById('sim-input-panel');
        const simLoadingPanel = document.getElementById('sim-loading-panel');
        const simResultsPanel = document.getElementById('sim-results-panel');
        
        const textToParse = document.getElementById('sim-textarea');

        // Parse Simulation
        if (btnSimulate && simInputPanel && simLoadingPanel && simResultsPanel) {
          btnSimulate.addEventListener('click', () => {
            simInputPanel.classList.add('hidden');
            simLoadingPanel.classList.remove('hidden');

            // Wait 1.6 seconds to mock server response
            setTimeout(() => {
              simLoadingPanel.classList.add('hidden');
              simResultsPanel.classList.remove('hidden');
              if (typeof lucide !== 'undefined') {
                lucide.createIcons(); // refresh icons in results panel
              }
            }, 1600);
          });
        }

        // Reset to initial textarea view
        if (btnReset && simInputPanel && simLoadingPanel && simResultsPanel) {
          btnReset.addEventListener('click', () => {
            simResultsPanel.classList.add('hidden');
            simInputPanel.classList.remove('hidden');
            // reset all check boxes
            const checkboxes = document.querySelectorAll('.sim-task-checkbox');
            checkboxes.forEach(c => {
              c.checked = false;
              const textSpan = c.parentNode.querySelector('.sim-task-title');
              if (textSpan) textSpan.classList.remove('line-through', 'opacity-40');
            });
          });
        }

        // Demo Text loader
        if (btnLoadDemo && textToParse) {
          btnLoadDemo.addEventListener('click', () => {
            textToParse.value = `Good morning mga magulang! 🌟

From: Ma'am Santos (Grade 3 - Sampaguita)

📚 HOMEWORK & ASSIGNMENTS:
- Math worksheet on fractions (pages 45-47) - due TOMORROW June 12
- Science project: Draw and label parts of a plant - due Friday June 14
- Filipino: Memorize "Lupang Hinirang" first 2 stanzas for recitation on Monday June 16

📅 UPCOMING EVENTS:
- FLAG CEREMONY will be held this Monday. Please remind your child to wear complete uniform including white shoes.
- PERIODICAL EXAM for Q4 is scheduled on June 20-21 (Thursday-Friday). Coverage sheet will be sent home tomorrow.

💰 FEES & REMINDERS:
- Book rental fee of ₱150 is due on June 15. Please pay to the class treasurer.
- Make sure your child brings their BAON.

Thank you!`;
          });
        }

        // Tabs Logic for Playground Results
        const btnTabTasks = document.getElementById('tab-btn-tasks');
        const btnTabAnns = document.getElementById('tab-btn-anns');
        const contentTasks = document.getElementById('tab-content-tasks');
        const contentAnns = document.getElementById('tab-content-anns');

        if (btnTabTasks && btnTabAnns && contentTasks && contentAnns) {
          btnTabTasks.addEventListener('click', () => {
            btnTabTasks.setAttribute('aria-selected', 'true');
            btnTabTasks.tabIndex = 0;
            btnTabAnns.setAttribute('aria-selected', 'false');
            btnTabAnns.tabIndex = -1;
            btnTabTasks.classList.add('border-indigo-500', 'text-white');
            btnTabTasks.classList.remove('border-transparent', 'text-slate-400');
            btnTabAnns.classList.remove('border-indigo-500', 'text-white');
            btnTabAnns.classList.add('border-transparent', 'text-slate-400');
            
            contentTasks.classList.remove('hidden');
            contentAnns.classList.add('hidden');
          });

          btnTabAnns.addEventListener('click', () => {
            btnTabAnns.setAttribute('aria-selected', 'true');
            btnTabAnns.tabIndex = 0;
            btnTabTasks.setAttribute('aria-selected', 'false');
            btnTabTasks.tabIndex = -1;
            btnTabAnns.classList.add('border-indigo-500', 'text-white');
            btnTabAnns.classList.remove('border-transparent', 'text-slate-400');
            btnTabTasks.classList.remove('border-indigo-500', 'text-white');
            btnTabTasks.classList.add('border-transparent', 'text-slate-400');
            
            contentAnns.classList.remove('hidden');
            contentTasks.classList.add('hidden');
          });

          [btnTabTasks, btnTabAnns].forEach((tab, index, tabs) => {
            tab.addEventListener('keydown', event => {
              if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
              event.preventDefault();
              const nextIndex = event.key === 'ArrowRight'
                ? (index + 1) % tabs.length
                : (index - 1 + tabs.length) % tabs.length;
              tabs[nextIndex].focus();
              tabs[nextIndex].click();
            });
          });
        }

        // Checkbox Cross-Out effect
        document.addEventListener('change', (e) => {
          if (e.target && e.target.classList.contains('sim-task-checkbox')) {
            const checkbox = e.target;
            const textSpan = checkbox.parentNode.querySelector('.sim-task-title');
            if (textSpan) {
              if (checkbox.checked) {
                textSpan.classList.add('line-through', 'opacity-40');
              } else {
                textSpan.classList.remove('line-through', 'opacity-40');
              }
            }
          }
        });
      </script>


